NODE_ENV=development

PORT=4000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

# JWT
JWT_SECRET=your_secret_min_32_chars

# Supabase Storage
SUPABASE_URL=https://[tu-proyecto-id].supabase.co
SUPABASE_ANON_KEY=[tu-anon-key]
SUPABASE_BUCKET=spotify-clone-bucket

# CORS: orígenes permitidos separados por coma.
# Déjalo vacío o sin definir para permitir cualquier origen (útil en desarrollo
# con clientes móviles). En producción con clientes web, especifica los dominios.
# Ejemplo: ALLOWED_ORIGINS=https://tu-dominio.com,https://app.tu-dominio.com
ALLOWED_ORIGINS=
